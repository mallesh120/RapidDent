# ──────────────────────────────────────────────────────
# RapidDent – Fastlane Configuration
# ──────────────────────────────────────────────────────

default_platform(:ios)

PROJECT    = "RapidDent.xcodeproj"
SCHEME     = "RapidDent"
BUNDLE_ID  = "com.manya.RapidDent"
TEAM_ID    = "U8B97NVD7G"
OUTPUT_DIR = "./build"

platform :ios do
  
  # Load App Store Connect API Key
  def api_key
    app_store_connect_api_key(
      key_id: "DB4BA7U46W",
      issuer_id: "8fd70bd2-5f11-4c32-a495-143caca99b44",
      key_filepath: "private_keys/AuthKey_DB4BA7U46W.p8",
      duration: 1200, # optional (seconds)
      in_house: false # optional but recommended for non-enterprise accounts
    )
  end

  # ── Build ──────────────────────────────────────────

  desc "Build the app (debug, no code-sign)"
  lane :build do
    xcodebuild(
      project: PROJECT,
      scheme: SCHEME,
      configuration: "Debug",
      destination: "generic/platform=iOS Simulator",
      build: true,
      clean: true,
      xcargs: "CODE_SIGNING_ALLOWED=NO"
    )
    UI.success("✅ Debug build succeeded")
  end

  desc "Build for release (archive-ready)"
  lane :build_release do
    gym(
      project: PROJECT,
      scheme: SCHEME,
      configuration: "Release",
      sdk: "iphoneos",
      clean: true,
      output_directory: OUTPUT_DIR,
      output_name: "RapidDent.ipa",
      export_method: "development",
      skip_codesigning: false
    )
    UI.success("✅ Release build succeeded → #{OUTPUT_DIR}/RapidDent.ipa")
  end

  # ── Test ───────────────────────────────────────────

  desc "Run unit tests"
  lane :test do
    scan(
      project: PROJECT,
      scheme: SCHEME,
      devices: ["iPhone 16"],
      clean: true,
      code_coverage: true,
      output_directory: "#{OUTPUT_DIR}/test_results"
    )
    UI.success("✅ Tests passed")
  end

  desc "Run UI tests"
  lane :ui_test do
    scan(
      project: PROJECT,
      scheme: SCHEME,
      devices: ["iPhone 16"],
      clean: true,
      only_testing: ["RapidDentUITests"],
      output_directory: "#{OUTPUT_DIR}/ui_test_results"
    )
    UI.success("✅ UI tests passed")
  end

  # ── Lint / Analyze ─────────────────────────────────

  desc "Static analysis with xcodebuild analyze"
  lane :analyze do
    xcodebuild(
      project: PROJECT,
      scheme: SCHEME,
      configuration: "Debug",
      destination: "generic/platform=iOS Simulator",
      analyze: true,
      xcargs: "CODE_SIGNING_ALLOWED=NO"
    )
    UI.success("✅ Analyze passed – no warnings")
  end

  # ── TestFlight Beta ────────────────────────────────

  desc "Build & upload to TestFlight"
  lane :beta do
    build_number = Time.now.strftime("%Y%m%d%H%M")

    gym(
      project: PROJECT,
      scheme: SCHEME,
      configuration: "Release",
      clean: true,
      output_directory: OUTPUT_DIR,
      output_name: "RapidDent.ipa",
      export_method: "app-store",
      destination: "generic/platform=iOS",
      xcargs: "CURRENT_PROJECT_VERSION=#{build_number}"
    )

    changelog = File.read("fastlane/release_notes.txt") rescue "Internal testing build."

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true,
      changelog: changelog
    )

    UI.success("🚀 Uploaded to TestFlight (build #{build_number})")
  end

  # ── App Store Release ──────────────────────────────

  desc "Build & submit to App Store for review"
  lane :release do
    build_number = Time.now.strftime("%Y%m%d%H%M")

    gym(
      project: PROJECT,
      scheme: SCHEME,
      configuration: "Release",
      sdk: "iphoneos",
      clean: true,
      output_directory: OUTPUT_DIR,
      output_name: "RapidDent.ipa",
      export_method: "app-store",
      xcargs: "CURRENT_PROJECT_VERSION=#{build_number}"
    )

    upload_to_app_store(
      api_key: api_key,
      force: true,
      skip_screenshots: true,
      skip_metadata: true
    )

    UI.success("🎉 Submitted to App Store review (build #{build_number})")
  end

  # ── Convenience ────────────────────────────────────

  desc "Upload existing IPA to TestFlight"
  lane :upload_only do |options|
    ipa_path = options[:ipa] || "#{OUTPUT_DIR}/RapidDent.ipa"
    upload_to_testflight(
      api_key: api_key,
      ipa: ipa_path,
      skip_waiting_for_build_processing: true
    )
  end

  desc "Clean derived data"
  lane :clean do
    clear_derived_data
    UI.success("🧹 Derived data cleared")
  end

  desc "Full CI pipeline: clean → build → test"
  lane :ci do
    clean
    build
    test
    UI.success("🏁 CI pipeline complete")
  end

end
